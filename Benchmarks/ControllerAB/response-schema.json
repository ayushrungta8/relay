{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case", "answer", "taskIds", "evidence"],
        "properties": {
          "case": {
            "type": "string",
            "enum": [
              "running",
              "attention",
              "atlas",
              "beacon",
              "old-task",
              "ambiguous"
            ]
          },
          "answer": {
            "type": "string",
            "enum": [
              "RUNNING",
              "NEEDS_INPUT",
              "ATLAS_FAILED",
              "BEACON_COMPLETE",
              "NEEDS_LOOKUP",
              "CLARIFY"
            ]
          },
          "taskIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": { "type": "string" }
        }
      }
    }
  }
}
